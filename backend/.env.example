# Comma-separated browser origins the FastAPI app may be called from
# API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Server-side (never expose in Next.js public env)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Disable anonymous dev user (production must set gateway/JWT and headers)
# API_ALLOW_DEV_USER=0

# App profile role for gateway-authenticated users (public.users.app_role) — must match DB
# X-User-App-Role: admin | doctor | staff

# LangChain: OpenAI for embeddings + compliance LLM (required for POST /v1/process-document)
# OPENAI_API_KEY=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_COMPLIANCE_MODEL=gpt-4o-mini

# Chroma persistence (defaults under backend/api/.chroma_data)
# CHROMA_PERSIST_DIRECTORY=
